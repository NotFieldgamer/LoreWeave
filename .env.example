# ---- Backend (copy to backend/.env and `set -a; source .env; set +a`, or export before running) ----
# Neo4j (local via docker-compose, or your AuraDB Free URI)
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=loreweave-dev

# Google Gemini — free tier key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key
# Narration + extraction model. gemini-2.0-flash returns free-tier limit:0; use 2.5-flash.
GEMINI_MODEL=gemini-2.5-flash
# The contradiction guard's cheap NLI classifier — a SEPARATE model so it has its own daily quota.
GUARD_MODEL=gemini-2.5-flash-lite

# Clerk — backend verifies Clerk-issued JWTs. From Clerk dashboard → API keys.
CLERK_ISSUER=https://your-subdomain.clerk.accounts.dev
CLERK_JWKS_URL=https://your-subdomain.clerk.accounts.dev/.well-known/jwks.json

# CORS: the deployed frontend origin (Vercel URL in prod, localhost in dev)
FRONTEND_ORIGIN=http://localhost:3000

# Turn rate limit (protects the Gemini free-tier quota). Optional overrides.
RATELIMIT_ENABLED=true
RATELIMIT_TURNS_PER_MINUTE=20

# Cloud Run injects PORT automatically; only set it for local overrides.
# PORT=8080

# ---- Frontend (copy to frontend/.env.local) ----
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
# The deployed backend URL (Cloud Run URL in prod, localhost in dev)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
